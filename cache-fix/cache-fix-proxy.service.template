[Unit]
Description=claude-code-cache-fix proxy (prompt-cache stabilizer)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=__NODE_BIN__ __NPM_ROOT__/claude-code-cache-fix/proxy/server.mjs
Environment=CACHE_FIX_PROXY_PORT=9801
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
